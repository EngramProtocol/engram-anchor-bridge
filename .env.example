# Required RPC endpoints
ENGRAM_RPC=http://127.0.0.1:26657
BABYLON_RPC=http://127.0.0.1:26657

# Required denomination on Babylon network
BABYLON_DENOM=ubbn

# Required wallet mnemonic for Babylon submission
# Never commit a real mnemonic to git
BABYLON_MNEMONIC=replace_with_real_mnemonic

# Memo prefix embedded in submitted payload
BABYLON_MEMO_PREFIX=engram-anchor

# Batch and polling behavior
BATCH_SIZE=200
POLL_INTERVAL_MS=1000

# Optional API endpoint for forwarding batch data
# Leave empty to disable external API forwarding
API_BASE_URL=

# Optional output file paths (absolute or relative)
HEIGHT_EPOCH_FILE=
BABYLON_ANCHOR_FILE=
BABYLON_PENDING_FILE=